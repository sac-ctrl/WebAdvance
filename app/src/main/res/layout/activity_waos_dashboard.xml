<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackgroundPrimary">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorSignature"
        android:title="WAOS Dashboard"
        android:titleTextColor="@android:color/white" />

    <TextView
        android:id="@+id/waos_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="Secure multi-app workspace with per-app downloads, clipboard, and vault"
        android:textColor="@color/md_theme_onSurfaceVariant"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@drawable/search_background">

        <TextView
            android:id="@+id/waos_app_count"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="0 apps"
            android:textColor="@color/md_theme_onSurface"
            android:textSize="14sp" />

        <Button
            android:id="@+id/button_sort_apps"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Sort"
            android:textAllCaps="false"
            android:backgroundTint="@color/md_theme_primary"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/button_toggle_layout"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:text="List"
            android:textAllCaps="false"
            android:backgroundTint="@color/md_theme_primary"
            android:textColor="@android:color/white" />

        <ImageButton
            android:id="@+id/button_refresh"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Refresh"
            android:padding="12dp"
            android:src="@drawable/ic_baseline_refresh_24"
            android:tint="@color/md_theme_onSurface" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipe_refresh_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/dashboard_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:clipToPadding="false"
                android:layoutAnimation="@anim/layout_slide_in_bottom" />
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/button_add_app"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="24dp"
            android:contentDescription="Add web app"
            app:srcCompat="@drawable/ic_add_24dp"
            android:tint="@android:color/white"
            android:backgroundTint="@color/colorSignature" />
    </FrameLayout>

    <Button
        android:id="@+id/button_launch_floating"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Launch Floating Bubble"
        android:backgroundTint="@color/colorSignature"
        android:textColor="@android:color/white" />

</LinearLayout>
