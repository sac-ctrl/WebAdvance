<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="6dp">

    <LinearLayout
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:background="@drawable/fw_panel_bg"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <!-- Panel header: site identity -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/fw_app_icon_bg">

                <TextView
                    android:id="@+id/panelAppIcon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="W"
                    android:textColor="@color/fw_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/panelAppTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:text="Web App"
                    android:textColor="@color/fw_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/panelAppUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:ellipsize="middle"
                    android:text="example.com"
                    android:textColor="@color/fw_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/fw_section_divider" />

        <!-- Section: Navigation -->
        <TextView
            style="@style/FwSectionLabel"
            android:text="NAVIGATION" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:weightSum="4">

            <FrameLayout
                style="@style/FwNavCell"
                android:layout_marginEnd="6dp">
                <ImageButton
                    android:id="@+id/navBack"
                    style="@style/FwNavButton"
                    android:contentDescription="Back"
                    android:src="@drawable/ic_baseline_arrow_back_24" />
            </FrameLayout>

            <FrameLayout
                style="@style/FwNavCell"
                android:layout_marginEnd="6dp">
                <ImageButton
                    android:id="@+id/navForward"
                    style="@style/FwNavButton"
                    android:contentDescription="Forward"
                    android:src="@drawable/ic_baseline_arrow_forward_24" />
            </FrameLayout>

            <FrameLayout
                style="@style/FwNavCell"
                android:layout_marginEnd="6dp">
                <ImageButton
                    android:id="@+id/navHome"
                    style="@style/FwNavButton"
                    android:contentDescription="Home"
                    android:src="@drawable/ic_baseline_home_24" />
            </FrameLayout>

            <FrameLayout style="@style/FwNavCell">
                <ImageButton
                    android:id="@+id/navRefresh"
                    style="@style/FwNavButton"
                    android:contentDescription="Refresh"
                    android:src="@drawable/ic_baseline_refresh_24" />
            </FrameLayout>
        </LinearLayout>

        <!-- Section: Modes (toggleable) -->
        <TextView
            style="@style/FwSectionLabel"
            android:layout_marginTop="14dp"
            android:text="MODES" />

        <include
            android:id="@+id/tileDesktop"
            layout="@layout/floating_action_tile"
            android:layout_marginTop="6dp" />

        <include
            android:id="@+id/tileAdblock"
            layout="@layout/floating_action_tile"
            android:layout_marginTop="6dp" />

        <include
            android:id="@+id/tileAutoScroll"
            layout="@layout/floating_action_tile"
            android:layout_marginTop="6dp" />

        <include
            android:id="@+id/tileAutoClick"
            layout="@layout/floating_action_tile"
            android:layout_marginTop="6dp" />

        <!-- Section: Page -->
        <TextView
            style="@style/FwSectionLabel"
            android:layout_marginTop="14dp"
            android:text="PAGE" />

        <include
            android:id="@+id/tileOpenBrowser"
            layout="@layout/floating_action_tile"
            android:layout_marginTop="6dp" />

        <include
            android:id="@+id/tileShare"
            layout="@layout/floating_action_tile"
            android:layout_marginTop="6dp" />

        <include
            android:id="@+id/tileCopyUrl"
            layout="@layout/floating_action_tile"
            android:layout_marginTop="6dp" />

        <!-- Section: Tools -->
        <TextView
            style="@style/FwSectionLabel"
            android:layout_marginTop="14dp"
            android:text="TOOLS" />

        <include
            android:id="@+id/tileCredentials"
            layout="@layout/floating_action_tile"
            android:layout_marginTop="6dp" />

        <include
            android:id="@+id/tileClipboard"
            layout="@layout/floating_action_tile"
            android:layout_marginTop="6dp" />

        <include
            android:id="@+id/tileDownloads"
            layout="@layout/floating_action_tile"
            android:layout_marginTop="6dp" />

    </LinearLayout>

</FrameLayout>
