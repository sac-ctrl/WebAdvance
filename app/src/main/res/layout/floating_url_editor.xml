<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="360dp"
        android:layout_height="wrap_content"
        android:background="@drawable/fw_url_editor_bg"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/fw_app_icon_bg">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="6dp"
                    android:src="@drawable/ic_fw_edit_16"
                    android:tint="@color/fw_text_primary" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Edit address"
                    android:textColor="@color/fw_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Type a URL or search query and tap Go"
                    android:textColor="@color/fw_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Input field with inline clear -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp">

            <EditText
                android:id="@+id/urlInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/fw_url_input_bg"
                android:hint="https://example.com"
                android:textColorHint="@color/fw_text_muted"
                android:textColor="@color/fw_text_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:singleLine="true"
                android:inputType="textUri"
                android:imeOptions="actionGo|flagNoExtractUi"
                android:paddingStart="14dp"
                android:paddingEnd="44dp"
                android:autofillHints="url"
                android:importantForAutofill="no" />

            <ImageButton
                android:id="@+id/urlClear"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="8dp"
                android:background="@drawable/fw_window_btn_default"
                android:contentDescription="Clear"
                android:padding="6dp"
                android:src="@drawable/ic_fw_close_circle_16"
                android:tint="@color/fw_text_secondary" />
        </FrameLayout>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/urlCancel"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/fw_btn_secondary_bg"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Cancel"
                android:textColor="@color/fw_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/urlGo"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/fw_btn_primary_bg"
                android:drawableStart="@drawable/ic_baseline_arrow_forward_24"
                android:drawablePadding="6dp"
                android:drawableTint="#0B1220"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="20dp"
                android:text="Go"
                android:textColor="#0B1220"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
