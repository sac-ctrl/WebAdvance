<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/card_background"
    android:elevation="6dp"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/waos_app_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_baseline_home_24"
            android:tint="@color/colorSignature"
            android:contentDescription="App icon"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/waos_app_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="App Title"
                android:textAppearance="?attr/textAppearanceHeadline6"
                android:textColor="@color/md_theme_onSurface" />

            <TextView
                android:id="@+id/waos_app_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Default Group"
                android:textAppearance="?attr/textAppearanceBody2"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/waos_app_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="https://example.com"
                android:textAppearance="?attr/textAppearanceBody2"
                android:textColor="@color/md_theme_onSurfaceVariant"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/waos_app_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="6dp"
            android:background="@drawable/status_chip_background"
            android:text="Active"
            android:textColor="@color/md_theme_onPrimary"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/waos_app_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap to open, long press for actions"
        android:textColor="@color/md_theme_onSurfaceVariant"
        android:textSize="13sp"
        android:layout_marginTop="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/button_open_app"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Open"
            android:textAllCaps="false"
            android:backgroundTint="@color/md_theme_primary"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/button_download_history"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Downloads"
            android:textAllCaps="false"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/button_clipboard"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Clipboard"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/button_credentials"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Vault"
            android:textAllCaps="false"
            android:layout_marginStart="8dp" />
    </LinearLayout>
</LinearLayout>
