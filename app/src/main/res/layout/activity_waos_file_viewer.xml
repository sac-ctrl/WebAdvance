<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackgroundPrimary">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorSignature"
        android:title="File Viewer"
        android:titleTextColor="@android:color/white"
        android:contentDescription="File viewer toolbar" />

    <LinearLayout
        android:id="@+id/file_info_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/file_name_text"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="@color/md_theme_onSurface"
            android:ellipsize="middle"
            android:singleLine="true"
            android:contentDescription="File name" />

        <TextView
            android:id="@+id/file_size_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="@color/md_theme_onSurfaceVariant"
            android:layout_marginStart="8dp"
            android:contentDescription="File size" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/file_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"
            android:textColor="@color/md_theme_onSurface"
            android:visibility="gone"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:scrollbars="vertical"
            android:contentDescription="File text content" />

        <ImageView
            android:id="@+id/file_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:visibility="gone"
            android:contentDescription="File image" />

        <VideoView
            android:id="@+id/file_video"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/file_error_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠"
                android:textSize="48sp"
                android:textColor="#F44336"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/file_error_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Could not open this file."
                android:textSize="16sp"
                android:textColor="@color/md_theme_onSurface"
                android:gravity="center"
                android:layout_marginBottom="24dp"
                android:contentDescription="Error message" />

            <Button
                android:id="@+id/button_open_external"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Open with another app"
                android:textAllCaps="false"
                android:backgroundTint="@color/md_theme_primary"
                android:textColor="@android:color/white"
                android:contentDescription="Open file with external app" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/file_action_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center"
        android:visibility="gone">

        <Button
            android:id="@+id/button_share_file"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Share"
            android:textAllCaps="false"
            android:backgroundTint="@color/md_theme_primary"
            android:textColor="@android:color/white"
            android:contentDescription="Share this file" />

        <Button
            android:id="@+id/button_fullscreen"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Full Screen"
            android:textAllCaps="false"
            android:contentDescription="Toggle full screen" />

        <Button
            android:id="@+id/button_open_other_app"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Open In"
            android:textAllCaps="false"
            android:contentDescription="Open in other app" />
    </LinearLayout>
</LinearLayout>
