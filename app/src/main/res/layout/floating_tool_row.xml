<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="6dp"
    android:background="@drawable/fw_panel_bg"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingEnd="6dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <ImageView
        android:id="@+id/rowIcon"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_marginEnd="10dp"
        android:src="@drawable/ic_fw_clipboard_24"
        android:tint="@color/fw_accent" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/rowPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Primary"
            android:textColor="@color/fw_text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/rowSecondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:singleLine="true"
            android:text="Secondary"
            android:textColor="@color/fw_text_secondary"
            android:textSize="11sp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/rowAction"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/fw_window_btn_default"
        android:contentDescription="Action"
        android:padding="8dp"
        android:src="@drawable/ic_baseline_content_copy_24"
        android:tint="@color/fw_text_secondary" />

</LinearLayout>
