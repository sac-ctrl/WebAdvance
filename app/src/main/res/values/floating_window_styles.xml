<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="FwSectionLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/fw_panel_section</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.14</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingTop">2dp</item>
        <item name="android:paddingBottom">2dp</item>
    </style>

    <style name="FwNavCell">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@drawable/fw_nav_button_bg</item>
    </style>

    <style name="FwNavButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:padding">10dp</item>
        <item name="android:tint">@color/fw_text_primary</item>
        <item name="android:scaleType">fitCenter</item>
    </style>

</resources>
