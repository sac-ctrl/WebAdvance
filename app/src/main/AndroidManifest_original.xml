<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="com.android.launcher.permission.INSTALL_SHORTCUT" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <meta-data android:name="android.webkit.WebView.EnableSafeBrowsing"
        android:value="false" />

    <application
        android:name="com.cylonid.nativealpha.util.App"
        android:allowBackup="true"
        android:icon="@mipmap/native_alpha"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/native_alpha"
        android:supportsRtl="true"
        android:screenOrientation="portrait"
        android:usesCleartextTraffic="true"
        android:resizeableActivity="true"
        android:fullBackupContent="true">

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <activity
            android:name="com.cylonid.nativealpha.MainActivity"
            android:launchMode="singleTask"
            android:theme="@style/AppTheme.Launcher"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.cylonid.nativealpha.waos.ui.WaosDashboardActivity"
            android:parentActivityName=".MainActivity"
            android:theme="@style/AppTheme"
            android:exported="false" />

        <activity
            android:name="com.cylonid.nativealpha.ui.UniversalFileViewerActivity"
            android:parentActivityName=".MainActivity"
            android:theme="@style/AppTheme"
            android:exported="false" />

        <activity
            android:name="com.cylonid.nativealpha.waos.ui.UniversalFileViewerActivity"
            android:parentActivityName=".MainActivity"
            android:theme="@style/AppTheme"
            android:exported="false" />

        <activity
            android:name="com.cylonid.nativealpha.ui.CredentialVaultActivity"
            android:parentActivityName=".MainActivity"
            android:theme="@style/AppTheme"
            android:exported="false" />

        <activity
            android:name="com.cylonid.nativealpha.waos.ui.CredentialVaultActivity"
            android:parentActivityName=".MainActivity"
            android:theme="@style/AppTheme"
            android:exported="false" />

        <activity
            android:name="com.cylonid.nativealpha.ui.ClipboardManagerActivity"
            android:parentActivityName=".MainActivity"
            android:theme="@style/AppTheme"
            android:exported="false" />

        <activity
            android:name="com.cylonid.nativealpha.waos.ui.ClipboardManagerActivity"
            android:parentActivityName=".MainActivity"
            android:theme="@style/AppTheme"
            android:exported="false" />

        <activity
            android:name="com.cylonid.nativealpha.waos.ui.DownloadHistoryActivity"
            android:parentActivityName=".MainActivity"
            android:theme="@style/AppTheme"
            android:exported="false" />

        <service
            android:name="com.cylonid.nativealpha.waos.service.FloatingWindowService"
            android:exported="false" />

<!--        Make sure to also copy changes to WebViewActivity in build.gradle-->
        <activity
            android:name=".WebViewActivity"
            android:parentActivityName=".MainActivity"
            android:windowSoftInputMode="adjustResize"
            android:icon="@mipmap/native_alpha"
            android:roundIcon="@mipmap/native_alpha"
            android:theme="@style/AppTheme.WebView"
            android:configChanges="orientation|screenSize|smallestScreenSize|density|screenLayout|uiMode|keyboard|keyboardHidden|navigation"
            android:launchMode="standard"
            android:documentLaunchMode="intoExisting"
            />
 
        <!--Placeholder-->
        <activity
            android:name="com.cylonid.nativealpha.SettingsActivity"
            android:parentActivityName=".MainActivity"
            android:icon="@mipmap/native_alpha"
            android:roundIcon="@mipmap/native_alpha"
            android:theme="@style/AppTheme">
        </activity>
        <activity
            android:name="com.cylonid.nativealpha.WebAppSettingsActivity"
            android:parentActivityName=".MainActivity"
            android:icon="@mipmap/native_alpha"
            android:roundIcon="@mipmap/native_alpha"
            android:theme="@style/AppTheme">
        </activity>

        <activity
            android:name="com.cylonid.nativealpha.AboutActivity"
            android:parentActivityName=".MainActivity"
            android:icon="@mipmap/native_alpha"
            android:roundIcon="@mipmap/native_alpha"
            android:theme="@style/AppTheme">
        </activity>

        <activity
            android:name="com.cylonid.nativealpha.activities.NewsActivity"
            android:parentActivityName=".MainActivity"
            android:icon="@mipmap/native_alpha"
            android:roundIcon="@mipmap/native_alpha"
            android:theme="@style/AppTheme">
        </activity>

        <activity
            android:name="com.cylonid.nativealpha.activities.AdblockConfigActivity"
            android:parentActivityName=".SettingsActivity"
            android:icon="@mipmap/native_alpha"
            android:roundIcon="@mipmap/native_alpha"
            android:theme="@style/AppTheme">
        </activity>

        <activity android:name="com.mikepenz.aboutlibraries.ui.LibsActivity"
            android:theme="@style/Theme.MaterialComponents.DayNight.NoActionBar">
        </activity>


        <meta-data android:name="com.samsung.android.keepalive.density" android:value="true"/>
        <meta-data android:name="com.samsung.android.multidisplay.keep_process_alive" android:value="true"/>
        <!--        https://developer.samsung.com/samsung-dex/modify-optimizing.html-->
    </application>

</manifest>