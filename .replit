modules = ["java-graalvm22.3", "web", "nodejs-20", "python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Android Build Info"

[[workflows.workflow]]
name = "Android Build Info"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'echo \"=== WAOS Android Project ===\"; echo \"Java: $(java -version 2>&1 | head -1)\"; echo \"Project: Native Alpha → WAOS\"; echo \"Build Flavor: standardDebug\"; echo \"\"; echo \"Features implemented:\"; echo \"  ✓ Dashboard (grid/list/sort/search/drag-drop)\"; echo \"  ✓ File Viewer (image/video/audio/pdf/text)\"; echo \"  ✓ Credential Vault (PIN/biometric)\"; echo \"  ✓ Clipboard Manager (per-app, swipe-delete)\"; echo \"  ✓ Download History\"; echo \"  ✓ Floating Window Service\"; echo \"  ✓ Session Isolation\"; echo \"\"; echo \"To build debug APK, push to GitHub and GitHub Actions will build it.\"; echo \"See .github/workflows/debug-apk.yml\"; while true; do sleep 60; echo \"[$(date)] Project ready\"; done'"

[workflows.workflow.metadata]
outputType = "console"
